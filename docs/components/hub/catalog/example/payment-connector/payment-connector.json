{
  "$schema": "https://unpkg.com/@camunda/element-templates-json-schema/resources/schema.json",
  "name": "Payment Connector",
  "id": "com.example.payment-connector",
  "description": "Initiate payments, check status, or process refunds via the company payment gateway.",
  "version": 1,
  "appliesTo": ["bpmn:ServiceTask"],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "operation",
      "label": "Operation"
    },
    {
      "id": "input",
      "label": "Input"
    },
    {
      "id": "output",
      "label": "Output"
    }
  ],
  "properties": [
    {
      "id": "operationType",
      "label": "Operation type",
      "group": "operation",
      "type": "Dropdown",
      "choices": [
        { "name": "Initiate payment", "value": "initiate" },
        { "name": "Check status", "value": "status" },
        { "name": "Process refund", "value": "refund" }
      ],
      "binding": {
        "type": "zeebe:input",
        "name": "operationType"
      }
    },
    {
      "id": "amount",
      "label": "Amount",
      "group": "input",
      "type": "String",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "amount"
      },
      "condition": {
        "property": "operationType",
        "oneOf": ["initiate", "refund"]
      }
    },
    {
      "id": "currency",
      "label": "Currency",
      "group": "input",
      "type": "String",
      "value": "USD",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "currency"
      },
      "condition": {
        "property": "operationType",
        "oneOf": ["initiate", "refund"]
      }
    },
    {
      "id": "paymentId",
      "label": "Payment ID",
      "group": "input",
      "type": "String",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "paymentId"
      },
      "condition": {
        "property": "operationType",
        "oneOf": ["status", "refund"]
      }
    },
    {
      "id": "resultVariable",
      "label": "Result variable",
      "group": "output",
      "type": "String",
      "value": "paymentResult",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultVariable"
      }
    },
    {
      "type": "Hidden",
      "value": "com.example.payment-connector",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    }
  ]
}
