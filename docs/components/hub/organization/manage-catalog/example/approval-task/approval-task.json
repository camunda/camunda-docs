{
  "$schema": "https://unpkg.com/@camunda/element-templates-json-schema/resources/schema.json",
  "name": "Approval Task",
  "id": "com.example.approval-task",
  "description": "Standardized approval user task with escalation and delegation support.",
  "version": 1,
  "appliesTo": ["bpmn:UserTask"],
  "elementType": {
    "value": "bpmn:UserTask"
  },
  "groups": [
    {
      "id": "approval",
      "label": "Approval"
    },
    {
      "id": "escalation",
      "label": "Escalation"
    }
  ],
  "properties": [
    {
      "id": "approverGroup",
      "label": "Approver group",
      "group": "approval",
      "type": "String",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "approverGroup"
      }
    },
    {
      "id": "approvalMode",
      "label": "Approval mode",
      "group": "approval",
      "type": "Dropdown",
      "value": "single",
      "choices": [
        { "name": "Single approver", "value": "single" },
        { "name": "Multi approver (all must approve)", "value": "all" },
        { "name": "Multi approver (majority)", "value": "majority" }
      ],
      "binding": {
        "type": "zeebe:input",
        "name": "approvalMode"
      }
    },
    {
      "id": "escalationEnabled",
      "label": "Enable escalation",
      "group": "escalation",
      "type": "Boolean",
      "value": "false",
      "binding": {
        "type": "zeebe:input",
        "name": "escalationEnabled"
      }
    },
    {
      "id": "escalationTimeout",
      "label": "Escalation timeout",
      "description": "Duration before the task is escalated (ISO 8601, e.g. PT24H).",
      "group": "escalation",
      "type": "String",
      "value": "PT24H",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "escalationTimeout"
      },
      "condition": {
        "property": "escalationEnabled",
        "equals": "true"
      }
    },
    {
      "id": "delegationAllowed",
      "label": "Allow delegation",
      "group": "escalation",
      "type": "Boolean",
      "value": "true",
      "binding": {
        "type": "zeebe:input",
        "name": "delegationAllowed"
      }
    }
  ]
}
